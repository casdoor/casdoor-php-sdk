{
    "name": "casdoor/casdoor-php-sdk",
    "description": "PHP client SDK for Casdoor",
    "license": "Apache-2.0",
    "keywords": [
        "casdoor",
        "oauth",
        "saml",
        "authentication",
        "auth",
        "sso",
        "oidc",
        "authn"
    ],
    "require": {
        "php": ">=8.0",
        "guzzlehttp/guzzle": "^7.3",
        "league/oauth2-client": "^2.6",
        "firebase/php-jwt": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "Casdoor\\": "src/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0|^10.0"
    },
    "autoload-dev": {
        "psr-4": {
            "Casdoor\\Tests\\": "tests/"
        }
    }
}
